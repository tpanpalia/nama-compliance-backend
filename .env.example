# =============================================================
# NAMA COMPLIANCE BACKEND — Environment Variables
# =============================================================
# Copy this file to .env.development, .env.uat, or .env.production
# and fill in real values. Never commit actual credentials.
# =============================================================

# App
NODE_ENV=development                        # development | uat | production
PORT=3000

# -------------------------------------------------------------
# DATABASE
# Dev  → Supabase (transaction pooler for queries, direct for migrations)
# UAT  → AWS RDS
# Prod → AWS RDS
# -------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname

# -------------------------------------------------------------
# STORAGE
# Set STORAGE_PROVIDER to switch between Supabase Storage and AWS S3.
# All other variables are provider-specific — only the active
# provider's variables need to be filled in.
# -------------------------------------------------------------
STORAGE_PROVIDER=supabase                   # supabase | s3

# Supabase Storage (dev only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=nws-compliance

# AWS S3 (uat + production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=nws-compliance
AWS_S3_ENDPOINT=                            # optional — leave blank for standard AWS S3

# -------------------------------------------------------------
# AUTH
# -------------------------------------------------------------
JWT_SECRET=                                 # min 64 chars, random string
JWT_EXPIRES_IN=15m                          # access token lifetime
JWT_REFRESH_EXPIRES_IN=7d                   # refresh token lifetime

# -------------------------------------------------------------
# CORS
# -------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173           # frontend URL — comma-separated for multiple
