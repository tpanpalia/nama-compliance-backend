# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database — AWS RDS PostgreSQL (Bahrain region)
DATABASE_URL="postgresql://nama_user:nama_password_123@localhost:5432/nama_compliance"

# Azure AD — Internal users (Inspectors + Admins)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_ISSUER=https://login.microsoftonline.com/your-tenant-id/v2.0
AZURE_AD_JWKS_URI=https://login.microsoftonline.com/your-tenant-id/discovery/v2.0/keys

# Azure AD B2C — External users (Contractors + Regulators)
AZURE_B2C_TENANT_NAME=your-b2c-tenant
AZURE_B2C_POLICY_NAME=B2C_1_signupsignin
AZURE_B2C_CLIENT_ID=your-b2c-client-id
AZURE_B2C_ISSUER=https://your-b2c-tenant.b2clogin.com/your-tenant-id/v2.0/
AZURE_B2C_JWKS_URI=https://your-b2c-tenant.b2clogin.com/your-b2c-tenant.onmicrosoft.com/discovery/v2.0/keys?p=B2C_1_signupsignin

# AWS S3 — Bahrain region (me-south-1)
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=nama-compliance-evidence
S3_PRESIGNED_URL_EXPIRES=3600

# App
JWT_SECRET=your-jwt-secret-min-32-chars
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
MAX_FILE_SIZE_PHOTO_MB=10
MAX_FILE_SIZE_VIDEO_MB=50
MAX_PHOTOS_PER_WORKORDER=20
MAX_VIDEOS_PER_WORKORDER=5
GPS_MAX_DISTANCE_METERS=100
GPS_MAX_ACCURACY_METERS=50
