generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  displayName        String
  role               UserRole
  organisation       String?
  department         String?
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  identity           Identity?
  auditLogs          AuditLog[]
  reportLogs         ReportLog[]
  approvedWorkOrders WorkOrder[] @relation("ApproverWorkOrders")
  createdWorkOrders  WorkOrder[] @relation("CreatorWorkOrders")
  assignedWorkOrders WorkOrder[] @relation("InspectorWorkOrders")
  accessRequests     AccessRequest[]

  @@index([role])
}

model Contractor {
  id            String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  contractorId  String         @unique
  companyName   String
  tradeLicense  String
  crNumber      String
  contactName   String
  phone         String
  address       String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  identity      Identity?
  accessRequest AccessRequest?
  itemComments  ContractorItemComment[]
  workOrders    WorkOrder[]
  @@index([isActive])
}

model Identity {
  id           String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  email        String       @unique
  password     String
  role         IdentityRole
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  userId       String?      @unique
  contractorId String?      @unique
  user         User?        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contractor   Contractor?  @relation(fields: [contractorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([email])
  @@index([role])
}

model Site {
  id         String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  name       String
  location   String
  latitude   Float
  longitude  Float
  region     String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  workOrders WorkOrder[]

  @@index([isActive])
  @@index([region])
}

model WorkOrder {
  id              String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  reference       String              @unique
  title           String
  description     String?
  status          WorkOrderStatus     @default(PENDING)
  priority        WorkOrderPriority   @default(MEDIUM)
  scheduledDate   DateTime?           @db.Timestamptz(6)
  startedAt       DateTime?           @db.Timestamptz(6)
  submittedAt     DateTime?           @db.Timestamptz(6)
  approvedAt      DateTime?           @db.Timestamptz(6)
  isLocked        Boolean             @default(false)
  overallScore    Float?
  complianceBand  ComplianceBand?
  rejectionReason String?
  siteId          String
  contractorId    String?
  inspectorId     String?
  createdById     String
  approvedById    String?
  createdAt       DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  auditLogs       AuditLog[]
  contractorComments ContractorItemComment[]
  evidence        Evidence[]
  approvedBy      User?               @relation("ApproverWorkOrders", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contractor      Contractor?         @relation(fields: [contractorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy       User                @relation("CreatorWorkOrders", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inspector       User?               @relation("InspectorWorkOrders", fields: [inspectorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  site            Site                @relation(fields: [siteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checklist       WorkOrderChecklist?

  @@index([status])
  @@index([inspectorId])
  @@index([contractorId])
  @@index([siteId])
  @@index([reference])
  @@index([createdAt])
  @@index([scheduledDate])
}

model ContractorItemComment {
  id              String     @id @default(uuid())
  workOrderId     String
  checklistItemId String
  contractorId    String
  comment         String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  workOrder       WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contractor      Contractor @relation(fields: [contractorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([workOrderId, checklistItemId, contractorId])
  @@map("ContractorItemComment")
  @@index([workOrderId])
  @@index([contractorId])
  @@index([checklistItemId])
}

model ChecklistTemplate {
  id          String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  description String?
  isActive    Boolean            @default(true)
  version     Int                @default(1)
  createdAt   DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  sections    ChecklistSection[]

  @@index([isActive])
}

model ChecklistSection {
  id            String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  name          String
  description   String?
  weight        Float
  order         Int
  templateId    String
  items         ChecklistItem[]
  template      ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([templateId])
  @@index([order])
}

model ChecklistItem {
  id         String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  text       String
  isRequired Boolean             @default(true)
  weight     Int                 @default(10)
  order      Int
  sectionId  String
  section    ChecklistSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  responses  ChecklistResponse[]
  evidence   Evidence[]

  @@index([sectionId])
  @@index([order])
}

model WorkOrderChecklist {
  id                 String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  workOrderId        String              @unique
  isSubmitted        Boolean             @default(false)
  submittedAt        DateTime?           @db.Timestamptz(6)
  lastSavedAt        DateTime?           @db.Timestamptz(6)
  submittedLatitude  Float?
  submittedLongitude Float?
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  responses          ChecklistResponse[]
  workOrder          WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ChecklistResponse {
  id          String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  checklistId String
  itemId      String
  rating      RatingValue?
  comment     String?
  createdAt   DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  checklist   WorkOrderChecklist @relation(fields: [checklistId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item        ChecklistItem      @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evidence    Evidence[]

  @@unique([checklistId, itemId])
  @@index([checklistId])
  @@index([rating])
}

model Evidence {
  id                 String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  workOrderId        String
  checklistItemId    String?
  checklistResponseId String?
  type               EvidenceType
  source             EvidenceSource
  s3Key              String
  s3Url              String?
  s3Bucket           String
  fileName           String
  fileSize           Int
  mimeType           String
  latitude           Float?
  longitude          Float?
  accuracy           Float?
  locationDisplayName String?
  locationShortName  String?
  locationCity       String?
  locationSuburb     String?
  locationCountry    String?
  isLocationFlagged  Boolean            @default(false)
  locationDistance   Float?
  isConfirmed        Boolean            @default(false)
  capturedAt         DateTime?          @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @db.Timestamptz(6)
  uploadedAt         DateTime           @default(now()) @db.Timestamptz(6)
  workOrder          WorkOrder          @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checklistItem      ChecklistItem?     @relation(fields: [checklistItemId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  checklistResponse  ChecklistResponse? @relation(fields: [checklistResponseId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([workOrderId])
  @@index([checklistItemId])
  @@index([checklistResponseId])
  @@index([source])
  @@index([type])
}

model AuditLog {
  id          String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  workOrderId String?
  userId      String?
  action      String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  user        User?      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([workOrderId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AccessRequest {
  id           String                  @id @default(uuid())
  requestId    String                  @unique
  role         AccessRequestType
  contactName  String
  email        String                  @unique
  phone        String
  companyName  String?
  tradeLicense String?
  crNumber     String?
  organisation String?
  department   String?
  status       AccessRequestStatus     @default(PENDING)
  reviewedAt   DateTime?
  reviewNotes  String?
  contractorId String?                 @unique
  userId       String?                 @unique
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  contractor   Contractor?             @relation(fields: [contractorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user         User?                   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents    AccessRequestDocument[]

  @@index([status])
  @@index([role])
  @@index([email])
  @@index([createdAt])
}

model AccessRequestDocument {
  id              String         @id @default(uuid())
  accessRequestId String
  name            String
  status          DocumentStatus @default(NOT_VERIFIED)
  fileUrl         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  accessRequest   AccessRequest  @relation(fields: [accessRequestId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([accessRequestId])
}

model ReportLog {
  id              String   @id @default(uuid())
  reportType      String
  subject         String
  period          String
  generatedBy     String
  generatedAt     DateTime @default(now())
  fileKey         String
  fileUrl         String
  fileSize        Int?
  filters         Json
  generatedByUser User     @relation(fields: [generatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("ReportLog")
  @@index([generatedAt])
  @@index([generatedBy])
}

enum UserRole {
  INSPECTOR
  ADMIN
  REGULATOR
}

enum IdentityRole {
  INSPECTOR
  ADMIN
  REGULATOR
  CONTRACTOR
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  INSPECTION_COMPLETED
  REJECTED
  REOPENED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RatingValue {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
}

enum EvidenceType {
  PHOTO
  VIDEO
}

enum EvidenceSource {
  INSPECTOR
  CONTRACTOR
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccessRequestType {
  CONTRACTOR
  REGULATOR
}

enum DocumentStatus {
  NOT_VERIFIED
  VERIFIED
  REJECTED
}

enum ComplianceBand {
  EXCELLENT
  GOOD
  FAIR
  POOR
}
