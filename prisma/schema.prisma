generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  email              String      @unique
  password           String
  displayName        String
  role               UserRole
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  assignedWorkOrders WorkOrder[] @relation("InspectorWorkOrders")
  createdWorkOrders  WorkOrder[] @relation("CreatorWorkOrders")
  approvedWorkOrders WorkOrder[] @relation("ApproverWorkOrders")
  auditLogs          AuditLog[]

  @@index([email])
  @@index([role])
}

model Contractor {
  id            String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  contractorId  String         @unique
  companyName   String
  tradeLicense  String
  crNumber      String
  contactName   String
  email         String         @unique
  password      String
  phone         String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  workOrders    WorkOrder[]
  accessRequest AccessRequest?

  @@index([contractorId])
  @@index([isActive])
}

model Site {
  id         String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  name       String
  location   String
  latitude   Float
  longitude  Float
  region     String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  workOrders WorkOrder[]

  @@index([isActive])
  @@index([region])
}

model WorkOrder {
  id              String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  reference       String              @unique
  title           String
  description     String?
  status          WorkOrderStatus     @default(PENDING)
  priority        WorkOrderPriority   @default(MEDIUM)
  scheduledDate   DateTime?           @db.Timestamptz(6)
  startedAt       DateTime?           @db.Timestamptz(6)
  submittedAt     DateTime?           @db.Timestamptz(6)
  approvedAt      DateTime?           @db.Timestamptz(6)
  isLocked        Boolean             @default(false)
  overallScore    Float?
  complianceBand  ComplianceBand?
  rejectionReason String?
  siteId          String
  contractorId    String?
  inspectorId     String?
  createdById     String
  approvedById    String?
  createdAt       DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  auditLogs       AuditLog[]
  evidence        Evidence[]
  approvedBy      User?               @relation("ApproverWorkOrders", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contractor      Contractor?         @relation(fields: [contractorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy       User                @relation("CreatorWorkOrders", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inspector       User?               @relation("InspectorWorkOrders", fields: [inspectorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  site            Site                @relation(fields: [siteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checklist       WorkOrderChecklist?

  @@index([status])
  @@index([inspectorId])
  @@index([contractorId])
  @@index([siteId])
  @@index([reference])
  @@index([scheduledDate])
}

model ChecklistTemplate {
  id          String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  description String?
  isActive    Boolean            @default(true)
  version     Int                @default(1)
  createdAt   DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  sections    ChecklistSection[]

  @@index([isActive])
}

model ChecklistSection {
  id         String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  name       String
  weight     Float
  order      Int
  templateId String
  items      ChecklistItem[]
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([templateId])
  @@index([order])
}

model ChecklistItem {
  id         String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  text       String
  isRequired Boolean             @default(true)
  order      Int
  sectionId  String
  section    ChecklistSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  responses  ChecklistResponse[]

  @@index([sectionId])
  @@index([order])
}

model WorkOrderChecklist {
  id                 String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  workOrderId        String              @unique
  isSubmitted        Boolean             @default(false)
  submittedAt        DateTime?           @db.Timestamptz(6)
  lastSavedAt        DateTime?           @db.Timestamptz(6)
  submittedLatitude  Float?
  submittedLongitude Float?
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  responses          ChecklistResponse[]
  workOrder          WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ChecklistResponse {
  id          String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  checklistId String
  itemId      String
  rating      RatingValue?
  comment     String?
  createdAt   DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  checklist   WorkOrderChecklist @relation(fields: [checklistId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item        ChecklistItem      @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([checklistId, itemId])
  @@index([checklistId])
  @@index([rating])
}

model Evidence {
  id          String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  workOrderId String
  type        EvidenceType
  source      EvidenceSource
  s3Key       String
  s3Bucket    String
  fileName    String
  fileSize    Int
  mimeType    String
  latitude    Float?
  longitude   Float?
  accuracy    Float?
  capturedAt  DateTime?      @db.Timestamptz(6)
  uploadedAt  DateTime       @default(now()) @db.Timestamptz(6)
  workOrder   WorkOrder      @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([workOrderId])
  @@index([source])
  @@index([type])
}

model AuditLog {
  id          String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  workOrderId String?
  userId      String?
  action      String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  user        User?      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([workOrderId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AccessRequest {
  id           String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  companyName  String
  tradeLicense String
  crNumber     String
  contactName  String
  email        String              @unique
  phone        String
  status       AccessRequestStatus @default(PENDING)
  reviewedAt   DateTime?           @db.Timestamptz(6)
  reviewNotes  String?
  contractorId String?             @unique
  createdAt    DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  contractor   Contractor?         @relation(fields: [contractorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status])
  @@index([email])
}

model ScoringConfig {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String   @unique
  weights   Json
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  updatedBy String?
}

enum UserRole {
  INSPECTOR
  ADMIN
}

enum ExternalUserRole {
  CONTRACTOR
  REGULATOR
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  REOPENED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RatingValue {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
}

enum EvidenceType {
  PHOTO
  VIDEO
}

enum EvidenceSource {
  INSPECTOR
  CONTRACTOR
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplianceBand {
  EXCELLENT
  GOOD
  FAIR
  POOR
}
